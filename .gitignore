# 排除日志和缓存
*.log
*.log.*
.cache/
.cache-*

# 排除临时文件
tmp/
temp/
*.tmp

# 排除 node_modules
node_modules/

# 排除大型数据文件
*.mdb
*.pst
*.ost

# 排除媒体文件（太大）
*.mp4
*.mp3
*.wav
*.pdf
*.zip
*.tar
*.tar.gz

# 排除会话历史文件
*.jsonl

# 排除特定大目录
agents/*/sessions/
agents/*/cache/
workspace-*/tmp/
workspace-*/memory/archive/
