# 排除大文件和临时文件
*.log
*.log.*

# 排除缓存
.cache/
.cache-*

# 排除临时文件
tmp/
temp/
*.tmp

# 排除 node_modules
node_modules/

# 排除大型数据文件
*.mdb
*.pst
*.ost

# 排除媒体文件（太大）
*.mp4
*.mp3
*.wav
*.pdf
*.zip
*.tar
*.tar.gz

# 排除会话历史文件
*.jsonl

# 排除密集目录
agents/*/sessions/
agents/*/cache/
workspace-*/tmp/
workspace-*/memory/archive/

# 只保留活跃记忆
memory/*.md
!memory/archive/

# 保留配置文件但排除大文件
config/
agents/
skills/
shared-memory/
workspaces/
